{
    "name": "hello_world",
    "version": "1.0.0",
    "description": "Security-hardened HTTPS application with comprehensive security middleware including helmet, rate limiting, CORS, and input validation",
    "main": "server.js",
    "engines": {
        "node": ">=14.0.0"
    },
    "scripts": {
        "start": "node server.js",
        "generate-cert": "openssl req -x509 -newkey rsa:2048 -keyout server.key -out server.cert -days 365 -nodes -subj '/CN=localhost'",
