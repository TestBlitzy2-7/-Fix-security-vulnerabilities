    },
    "dependencies": {
        "express": "^4.21.2",
        "helmet": "^8.0.0",
        "express-rate-limit": "^7.5.0",
        "cors": "^2.8.5",
        "express-validator": "^7.2.1"
    },
    "keywords": [
        "https",
        "security",
        "express",
        "helmet",
        "rate-limiting",
        "cors",
        "validation",
        "tls",
        "ssl"
    ],
